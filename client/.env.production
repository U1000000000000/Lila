# Production environment — loaded automatically by Vite for production builds.
# Vercel: add these as Project → Settings → Environment Variables as well.
#
# To switch to production mode locally: VITE_APP_ENV=production vite build

# ── Environment mode ──────────────────────────────────────────────────────────
VITE_APP_ENV=production

# ── API & WebSocket ───────────────────────────────────────────────────────────
# Full absolute URLs — no Vite proxy exists in production builds.
VITE_API_BASE_URL=https://lila.zeabur.app/api/v1
VITE_WS_BASE_URL=wss://lila.zeabur.app/ws

# ── Google OAuth redirect ─────────────────────────────────────────────────────
# Browser navigates here directly to start the OAuth flow.
VITE_BACKEND_ORIGIN=https://lila.zeabur.app
