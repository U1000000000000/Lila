# Production environment — loaded automatically by Vite for production builds.
# Vercel: add these as Project → Settings → Environment Variables as well.
#
# To switch to production mode locally: VITE_APP_ENV=production vite build

# ── Environment mode ──────────────────────────────────────────────────────────
VITE_APP_ENV=production

# ── API & WebSocket ───────────────────────────────────────────────────────────
# API uses relative URL — goes through Vercel rewrite proxy to Zeabur.
# This makes cookies first-party (vercel.app domain), solving Safari/Firefox.
VITE_API_BASE_URL=/api/v1

# WebSocket must connect directly to Zeabur because Vercel doesn't proxy WebSocket.
# Auth uses a short-lived token from GET /auth/ws-token instead of cookies.
VITE_WS_BASE_URL=wss://lila.zeabur.app/ws

# ── Google OAuth redirect ─────────────────────────────────────────────────────
# OAuth goes through Vercel proxy, so use relative URL.
VITE_BACKEND_ORIGIN=
