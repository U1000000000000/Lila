# ── Python runtime ────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyd
*.so
*.egg
*.egg-info/

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
.venv/
env/
.env_dir/

# ── Build / distribution ──────────────────────────────────────────────────────
dist/
build/
*.spec

# ── Environment Variables ──────────────────────────────────────────────────────
