# Copy this file to .env and fill in your real values.
# Never commit the actual .env file.

# ── Environment mode ──────────────────────────────────────────────────────────
# "development" → uses *_LOCAL URLs below.
# "production"  → uses the production URLs below.
# Flip this single variable when deploying — no other code changes needed.
APP_ENV=development

# ── URLs ──────────────────────────────────────────────────────────────────────
# All four must be defined.  APP_ENV selects which pair is active.
# Production (Zeabur / Vercel)
FRONTEND_URL=https://lilakreis.vercel.app
BACKEND_URL=https://lila.zeabur.app
# Local development
FRONTEND_URL_LOCAL=http://localhost:5173
BACKEND_URL_LOCAL=http://localhost:8000

# GOOGLE_REDIRECT_URI is auto-derived from BACKEND_URL / BACKEND_URL_LOCAL.
# Override here only if your callback path differs from the default:
# GOOGLE_REDIRECT_URI=https://lila.zeabur.app/api/v1/auth/google/callback

# CORS_ORIGINS is auto-derived from FRONTEND_URL / FRONTEND_URL_LOCAL.
# Override here only to allow extra origins (comma-separated):
# CORS_ORIGINS=https://lilakreis.vercel.app,https://preview.lilakreis.vercel.app

# ── External APIs ─────────────────────────────────────────────────────────────
DEEPGRAM_STT_URL=wss://api.deepgram.com/v1/listen?model=nova-3
DEEPGRAM_TTS_URL=wss://api.deepgram.com/v1/speak?model=aura-luna-en&encoding=linear16&sample_rate=24000
DEEPGRAM_API_KEY=your_deepgram_api_key_here

GROQ_API_KEY=your_groq_api_key_here

# Gemini — conversation analysis (get key at https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000

# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<AppName>
MONGODB_DB_NAME=appdb
